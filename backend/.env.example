# ── 上游供应商凭证（配了哪家就能用哪家的模型，全部可选）──
# LiteLLM 内核按模型目录路由，凭证按 provider 的 credential_env 读取
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=AIzaSy...
DEEPSEEK_API_KEY=your-deepseek-api-key
MISTRAL_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
# 更多聚合器 / 供应商（P14，配了才会真正可调用对应模型）
OPENROUTER_API_KEY=
FIREWORKS_API_KEY=
TOGETHER_API_KEY=
DEEPINFRA_API_KEY=
NOVITA_API_KEY=
PERPLEXITY_API_KEY=
MOONSHOT_API_KEY=
NEBIUS_API_KEY=
COHERE_API_KEY=
VOYAGE_API_KEY=

# ── 管理器配置 ──
# 平台超管 token（供应商/目录等平台级运维）
ADMIN_TOKEN=your-strong-admin-token-here
# 用户 JWT 密钥（多租户登录）——生产务必用 `openssl rand -hex 32` 生成
JWT_SECRET=change-me-please-set-a-32byte-min-jwt-secret-in-env
# 路由：单次请求最多尝试的通道数（首个 + 故障转移）
MAX_RETRIES=2
# 通道鉴权错误自动禁用；上游调用超时（秒）
CHANNEL_AUTO_DISABLE=false
# 定时通道巡检间隔（秒，0=关闭）
CHANNEL_HEALTH_CHECK_INTERVAL=0
UPSTREAM_TIMEOUT=600
# 缓存：相同请求去重复用；命中成本折算 multiplier（0=免费）；REDIS_URL 空=内存缓存
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_HIT_COST_MULTIPLIER=0.0
# 上游 prompt 缓存读 token 计价折扣（0.25 = 1/4 价）
CACHE_READ_PRICE_RATIO=0.25
# 把 reasoning_content 合并进 content（<think> 标签）
MERGE_REASONING_CONTENT=false
REDIS_URL=
# 第三方登录（留空则不启用该 provider）
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_DISCORD_CLIENT_ID=
OAUTH_DISCORD_CLIENT_SECRET=
# 通用 OIDC（任意 IdP）
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISPLAY_NAME=OIDC
DATABASE_URL=sqlite+aiosqlite:///./data/token_manager.db
HOST=0.0.0.0
PORT=8000
