# ── 上游供应商凭证（配了哪家就能用哪家的模型，全部可选）──
# LiteLLM 内核按模型目录路由，凭证按 provider 的 credential_env 读取
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=AIzaSy...
DEEPSEEK_API_KEY=your-deepseek-api-key
MISTRAL_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=

# ── 管理器配置 ──
# 平台超管 token（供应商/目录等平台级运维）
ADMIN_TOKEN=your-strong-admin-token-here
# 用户 JWT 密钥（多租户登录）——生产务必用 `openssl rand -hex 32` 生成
JWT_SECRET=change-me-please-set-a-32byte-min-jwt-secret-in-env
# 计费：新组织赠送额度（USD）；余额<=0 是否拦截调用
WELCOME_CREDIT_USD=5.0
ENFORCE_CREDIT_BALANCE=true
DATABASE_URL=sqlite+aiosqlite:///./data/token_manager.db
HOST=0.0.0.0
PORT=8000
